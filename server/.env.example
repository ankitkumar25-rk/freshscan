# =============================================
#  FreshScan — Environment Variables Template
#  Copy this to .env and fill in your values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/freshscan?retryWrites=true&w=majority

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Arduino device auth key
DEVICE_SECRET_KEY=your_secret_here

# CORS — set to your Vercel URL in production
CLIENT_ORIGIN=http://localhost:5173
